rules_version = '2';

// O backend acessa o Firestore via Admin SDK (ignora estas regras). O frontend
// NÃO fala com o Firestore diretamente — só usa o Realtime Database (chat) e o
// Firebase Auth. Portanto, bloqueamos todo acesso de cliente ao Firestore.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
